#!/usr/bin/env bash
#
# journal - a todo.txt-style journal grouped by project.
#
# Usage:
#   journal a[dd] some entry text              # add an unassigned entry (top)
#   journal a[dd] '+alias=Display Name' text   # create/name a project, add an entry
#   journal a[dd] +alias some entry text       # add an entry to a project
#   journal a[dd] '+alias=New Name'            # rename a project (no entry text)
#   journal n[ote] +alias '*Scope:* text'      # add an undated note (below title)
#   journal ls                                 # show the whole journal
#   journal ls +alias                          # show one section
#   journal ls @context                        # entries with @context, grouped
#   journal ls TERM                            # entries containing TERM, grouped
#   journal import [done.txt]                  # import completed todo.txt tasks
#   journal e[dit]                             # open the journal in $EDITOR
#   journal -h                                 # this help
#
# ls and list are synonyms. Quote any token with spaces. File is $JOURNAL_FILE,
# or ~/journal.txt.
#
# import reads todo.txt "done.txt" lines ("x <done> [<created>] [+proj] text"),
# files each under its +project (or the top blob), dated by completion date and
# tagged "created:<date>". The source defaults to $DONE_FILE or ~/done.txt and is
# left untouched; imported lines are logged to $JOURNAL_FILE.imported so re-runs
# skip them.
#
# Config: an optional file (default ~/.journal.txt.cfg, or $JOURNAL_CONFIG) may
# set JOURNAL_FILE, DONE_FILE, or the C_* colors below. `ls` colorizes when
# stdout is a terminal; set JOURNAL_PLAIN=1 in the config to disable. It also
# renders "[text](url)" markdown links as clickable OSC 8 hyperlinks; set
# JOURNAL_NO_LINKS=1 for terminals that don't support them (keeps raw markdown).
# "**bold**" and "__italic__" render as ANSI emphasis; set JOURNAL_NO_MD=1 to
# keep the raw markers. Set JOURNAL_WIDTH=N to wrap long lines at N columns, with
# continuations hang-indented under the bullet text.

set -euo pipefail

CONFIG="${JOURNAL_CONFIG:-$HOME/.journal.txt.cfg}"
# shellcheck source=/dev/null
[[ -f "$CONFIG" ]] && . "$CONFIG"

JOURNAL_FILE="${JOURNAL_FILE:-$HOME/journal.txt}"
touch "$JOURNAL_FILE"
today="$(date +%F)"

# Color codes for `ls`, overridable from the config file. Applied to headings
# (whole line) and to date / +project / @context / key:value tokens in entries.
C_HEAD="${C_HEAD:-$'\033[1m'}"    # bold
C_DATE="${C_DATE:-$'\033[34m'}"   # blue
C_PROJ="${C_PROJ:-$'\033[32m'}"   # green
C_CTX="${C_CTX:-$'\033[33m'}"     # yellow
C_META="${C_META:-$'\033[2m'}"    # dim
C_LINK="${C_LINK:-$'\033[4m'}"    # underline (markdown link text)
C_RESET="${C_RESET:-$'\033[0m'}"

# Color on when writing to a terminal, unless JOURNAL_PLAIN is set.
if [[ -t 1 && -z "${JOURNAL_PLAIN:-}" ]]; then COLOR=1; else COLOR=0; fi
# Render markdown links as OSC 8 hyperlinks (clickable link text, URL hidden),
# unless the terminal lacks support: set JOURNAL_NO_LINKS=1 to keep raw markdown.
if [[ "$COLOR" == 1 && -z "${JOURNAL_NO_LINKS:-}" ]]; then LINKS=1; else LINKS=0; fi
# Render "**bold**" and "__italic__" as ANSI emphasis; set JOURNAL_NO_MD=1 to keep
# the raw markers.
if [[ "$COLOR" == 1 && -z "${JOURNAL_NO_MD:-}" ]]; then MD=1; else MD=0; fi
# Wrap `ls` lines at JOURNAL_WIDTH columns (0 = off). Continuation lines hang-indent
# to line up under the bullet text (past the "- ").
WIDTH="${JOURNAL_WIDTH:-0}"
[[ "$WIDTH" =~ ^[0-9]+$ ]] || WIDTH=0

# is_heading(): line is "YYYY-MM-DD ... +alias ...". Prepended to each awk below.
IS_HEADING='
  function is_heading(  i) {
    if ($1 !~ /^[0-9]{4}-[0-9]{2}-[0-9]{2}$/) return 0
    for (i = 2; i <= NF; i++) if ($i ~ /^\+/) return 1
    return 0
  }'

# User text reaches awk via ENVIRON[...], not -v, to avoid backslash escaping.

usage() {
  local code="${1:-2}" fd=2
  [[ $code -eq 0 ]] && fd=1
  awk '/^#!/ { next } /^#/ { sub(/^#\ ?/, ""); print; next } { exit }' "$0" >&"$fd"
  exit "$code"
}

# Colorize `ls` output on stdin when $COLOR is 1; otherwise pass through. Headings
# are bold; within entries the leading date, +project, @context, and key:value
# metadata tokens are tinted. When $LINKS is 1, "[text](url)" tokens become OSC 8
# hyperlinks: clickable link text (underlined), URL hidden. When $MD is 1,
# "**bold**" and "__italic__" become ANSI emphasis. Styles come from C_*.
colorize() {
  if [[ "$COLOR" != 1 ]]; then cat; return; fi
  LINKS="$LINKS" MD="$MD" WIDTH="$WIDTH" \
  C_HEAD="$C_HEAD" C_DATE="$C_DATE" C_PROJ="$C_PROJ" C_CTX="$C_CTX" \
  C_META="$C_META" C_LINK="$C_LINK" C_RESET="$C_RESET" awk "$IS_HEADING"'
    { hd=ENVIRON["C_HEAD"]; dt=ENVIRON["C_DATE"]; pj=ENVIRON["C_PROJ"]
      cx=ENVIRON["C_CTX"]; mt=ENVIRON["C_META"]; lk=ENVIRON["C_LINK"]
      rs=ENVIRON["C_RESET"]; links=ENVIRON["LINKS"]; md=ENVIRON["MD"]
      esc=sprintf("%c", 27); bel=sprintf("%c", 7)
      bold=esc "[1m"; ital=esc "[3m"
      wd=ENVIRON["WIDTH"]+0; clos=esc "]8;;" esc "\\" }
    # Wrap "text"/"url" as an OSC 8 hyperlink (clickable text, URL hidden).
    function mklink(text, url) {
      return esc "]8;;" url esc "\\" lk text rs esc "]8;;" esc "\\"
    }
    # Tint one whitespace-delimited word by its kind (date/+project/@context/meta).
    function colorWord(w,  c) {
      c = ""
      if (w ~ /^[0-9]{4}-[0-9]{2}-[0-9]{2}$/) c = dt
      else if (w ~ /^\+./) c = pj
      else if (w ~ /^@./) c = cx
      else if (w ~ /^[^:[:space:]]+:[^:[:space:]]+$/) c = mt
      return c w (c != "" ? rs : "")
    }
    # Render an entry line: scan left to right, turning "[text](url)" into an OSC 8
    # hyperlink (text may contain spaces; trailing punctuation after ")" is left
    # out) and tinting every other word. Whitespace is copied verbatim.
    function renderEntry(s,  out, n, i, ch, rb, rp, text, url, word) {
      out = ""; n = length(s); i = 1
      while (i <= n) {
        ch = substr(s, i, 1)
        if (ch == " " || ch == "\t") { out = out ch; i++; continue }
        if (links == "1" && ch == "[") {                # try a link starting here
          rb = index(substr(s, i + 1), "]")             # "]" relative to i+1
          if (rb > 0) {
            rb = i + rb                                 # absolute pos of "]"
            if (substr(s, rb + 1, 1) == "(") {
              rp = index(substr(s, rb + 2), ")")        # ")" relative to rb+2
              if (rp > 0) {
                rp = rb + 1 + rp                        # absolute pos of ")"
                text = substr(s, i + 1, rb - i - 1)
                url  = substr(s, rb + 2, rp - rb - 2)
                out = out mklink(text, url); i = rp + 1
                continue
              }
            }
          }
        }
        word = ""                                       # a normal word
        while (i <= n) { ch = substr(s, i, 1); if (ch == " " || ch == "\t") break; word = word ch; i++ }
        out = out colorWord(word)
      }
      return out
    }
    # Replace paired "**...**"/"__...__" in plain text t with ANSI emphasis.
    # Unmatched (odd) markers are left as-is.
    function pairs(t, mark, code,  res, rest, p, q) {
      while ((p = index(t, mark)) > 0) {
        rest = substr(t, p + 2); q = index(rest, mark)
        if (q == 0) break
        res = res substr(t, 1, p - 1) code substr(rest, 1, q - 1) rs
        t = substr(rest, q + 2)
      }
      return res t
    }
    function applyEmph(t) { return pairs(pairs(t, "**", bold), "__", ital) }
    # Apply emphasis to visible text only, copying ANSI/OSC escape sequences
    # verbatim so hidden URLs and color codes are never touched.
    function emph(s,  out, i, n, c, nx, j, buf) {
      n = length(s); out = ""; buf = ""; i = 1
      while (i <= n) {
        c = substr(s, i, 1)
        if (c != esc) { buf = buf c; i++; continue }
        out = out applyEmph(buf); buf = ""
        nx = substr(s, i + 1, 1)
        if (nx == "[") {                                  # CSI: ESC [ ... letter
          j = i + 2
          while (j <= n && substr(s, j, 1) !~ /[a-zA-Z]/) j++
        } else if (nx == "]") {                           # OSC: ESC ] ... ESC\ | BEL
          j = i + 2
          while (j <= n) {
            if (substr(s, j, 1) == bel) break
            if (substr(s, j, 1) == esc && substr(s, j + 1, 1) == "\\") { j++; break }
            j++
          }
        } else { j = i + 1 }
        out = out substr(s, i, j - i + 1); i = j + 1
      }
      return out applyEmph(buf)
    }
    # Visible text of s: the string with all ANSI/OSC escape sequences removed.
    # Used to measure true width and find the bullet indent.
    function visible(s,  out, n, i, ch, nx, j) {
      out = ""; n = length(s); i = 1
      while (i <= n) {
        ch = substr(s, i, 1)
        if (ch == esc) {
          nx = substr(s, i + 1, 1)
          if (nx == "[") { j = i + 2; while (j <= n && substr(s, j, 1) !~ /[a-zA-Z]/) j++ }
          else if (nx == "]") {
            j = i + 2
            while (j <= n) {
              if (substr(s, j, 1) == bel) break
              if (substr(s, j, 1) == esc && substr(s, j + 1, 1) == "\\") { j++; break }
              j++
            }
          } else j = i + 1
          i = j + 1; continue
        }
        out = out ch; i++
      }
      return out
    }
    # Peel the next unit of s starting at index i, returning the next index and
    # setting the globals: unit (its text, escapes included), uwid (visible width),
    # uspace (1 if a run of blanks). A whole OSC 8 hyperlink is one unbreakable unit,
    # so spaces inside link text never become wrap points.
    function nextunit(s, i,  n, ch, nx, j, seq, link) {
      n = length(s); unit = ""; uwid = 0; uspace = 0
      ch = substr(s, i, 1)
      if (ch == " " || ch == "\t") {                     # a run of blanks
        uspace = 1
        while (i <= n) { ch = substr(s, i, 1); if (ch != " " && ch != "\t") break; unit = unit ch; uwid++; i++ }
        return i
      }
      link = 0
      while (i <= n) {                                   # a word, up to unescaped blank
        ch = substr(s, i, 1)
        if ((ch == " " || ch == "\t") && !link) break
        if (ch == esc) {
          nx = substr(s, i + 1, 1)
          if (nx == "[") { j = i + 2; while (j <= n && substr(s, j, 1) !~ /[a-zA-Z]/) j++ }
          else if (nx == "]") {
            j = i + 2
            while (j <= n) {
              if (substr(s, j, 1) == bel) break
              if (substr(s, j, 1) == esc && substr(s, j + 1, 1) == "\\") { j++; break }
              j++
            }
          } else j = i + 1
          seq = substr(s, i, j - i + 1)
          if (seq == clos) link = 0                      # OSC 8 close ends the link
          else if (substr(seq, 1, 5) == esc "]8;;") link = 1   # OSC 8 open starts it
          unit = unit seq; i = j + 1; continue
        }
        unit = unit ch; uwid++; i++
      }
      return i
    }
    # Wrap s to wd columns, hang-indenting continuations under the bullet text (the
    # "- " prefix). Escapes are zero-width and never split; words wider than the line
    # overflow rather than break. Returns s unchanged when wd<=0 or it already fits.
    function vwrap(s,  V, lead, indent, pad, k, n, i, col, out, first, psp, pwid) {
      if (wd <= 0) return s
      V = visible(s)
      if (length(V) <= wd) return s
      match(V, /^[ \t]*/); lead = RLENGTH
      indent = (substr(V, lead + 1, 2) == "- ") ? lead + 2 : lead
      pad = ""; for (k = 0; k < indent; k++) pad = pad " "
      n = length(s); i = 1; col = 0; out = ""; first = 1; psp = ""; pwid = 0
      while (i <= n) {
        i = nextunit(s, i)
        if (uspace) { psp = psp unit; pwid += uwid; continue }
        if (first) { out = unit; col = uwid; first = 0; psp = ""; pwid = 0; continue }
        if (col + pwid + uwid > wd) { out = out "\n" pad unit; col = indent + uwid }
        else { out = out psp unit; col += pwid + uwid }
        psp = ""; pwid = 0
      }
      return out
    }
    is_heading() { print vwrap(hd $0 rs); next }
    {
      out = renderEntry($0)
      print vwrap(md == "1" ? emph(out) : out)
    }
  '
}

# Show entries matching a term, grouped under their project headings. A term
# starting with "@" matches a whole field (context); otherwise it's a literal
# substring of the line.
show_grouped() {
  term="$1" awk "$IS_HEADING"'
    function hit(  i) {
      if (ENVIRON["term"] ~ /^@/) {
        for (i = 1; i <= NF; i++) if ($i == ENVIRON["term"]) return 1
        return 0
      }
      return index($0, ENVIRON["term"]) > 0
    }
    is_heading() { head = $0; shown = 0; next }
    hit() {
      if (!shown) { if (group++) print ""; if (head != "") print head; shown = 1 }
      print
    }
  ' "$JOURNAL_FILE"
}

# Show a whole project section by alias.
show_section() {
  alias="$1" awk "$IS_HEADING"'
    is_heading() {
      show = 0
      for (i = 2; i <= NF; i++) if ($i == "+" ENVIRON["alias"]) show = 1
    }
    show
  ' "$JOURNAL_FILE"
}

# Insert an entry, keeping each section newest-first by date. Args:
#   $1 alias  ""=top blob, else project (created if new)
#   $2 name   rename the project heading if non-empty
#   $3 entry  the "- DATE text" line ("" to only create/rename a section)
#   $4 edate  the entry's date, used both to place it and to date a new heading
#   $5 note   1 = an undated note, placed above all dated entries (after existing
#             notes); 0 = a dated entry, slotted in by date. Optional, defaults 0.
# A live add passes today's date so it lands on top, as before; import passes a
# past completion date so it slots in chronologically. Notes ignore edate for
# placement but still date a new heading with it.
insert_entry() {
  local tmp; tmp="$(mktemp "$JOURNAL_FILE.XXXXXX")"
  alias="$1" name="$2" entry="$3" edate="$4" note="${5:-0}" awk "$IS_HEADING"'
    function bdate(s,  a) {
      if (s ~ /^- [0-9]{4}-[0-9]{2}-[0-9]{2}/) { split(s, a, " "); return a[2] }
      return ""
    }
    function matches(  i) { for (i = 2; i <= NF; i++) if ($i == "+" alias) return 1; return 0 }
    # Is line L[i] the insertion point? A note stops at the first dated entry; a
    # dated entry stops at the first entry dated on or before it.
    function stop(i,  d) { d = bdate(L[i]); return d != "" && (note ? 1 : d <= edate) }
    { L[NR] = $0 }
    END {
      alias = ENVIRON["alias"]; name = ENVIRON["name"]
      entry = ENVIRON["entry"]; edate = ENVIRON["edate"]
      note = (ENVIRON["note"] == "1"); n = NR

      if (n == 0) {                                   # empty file
        if (alias != "") print edate (name != "" ? " " name : "") " +" alias
        if (entry != "") print entry
        exit
      }

      fh = hstart = 0                                 # first heading, target heading
      for (i = 1; i <= n; i++) {
        $0 = L[i]
        if (is_heading()) { if (!fh) fh = i; if (alias != "" && !hstart && matches()) hstart = i }
      }

      if (alias == "") {                              # top blob
        blobend = fh ? fh - 1 : n
        ins = 0
        for (i = 1; i <= blobend; i++) if (stop(i)) { ins = i; break }
        if (!ins) ins = blobend + 1
      } else if (!hstart) {                           # new section at end
        for (i = 1; i <= n; i++) print L[i]
        if (L[n] !~ /^[[:space:]]*$/) print ""
        print edate (name != "" ? " " name : "") " +" alias
        if (entry != "") print entry
        exit
      } else {                                        # existing section
        if (name != "") { $0 = L[hstart]; L[hstart] = $1 " " name " +" alias }
        secend = n
        for (i = hstart + 1; i <= n; i++) { $0 = L[i]; if (is_heading()) { secend = i - 1; break } }
        ins = 0
        for (i = hstart + 1; i <= secend; i++) if (stop(i)) { ins = i; break }
        if (!ins) { last = hstart; for (i = hstart + 1; i <= secend; i++) if (L[i] !~ /^[[:space:]]*$/) last = i; ins = last + 1 }
      }

      $0 = L[ins]; blob_before_head = (alias == "" && ins <= n && is_heading())
      for (i = 1; i <= n; i++) {
        if (i == ins && entry != "") { print entry; if (blob_before_head) print "" }
        print L[i]
      }
      if (ins == n + 1 && entry != "") print entry
    }
  ' "$JOURNAL_FILE" > "$tmp"
  mv "$tmp" "$JOURNAL_FILE"
}

# Import completed todo.txt tasks ("x <done> [<created>] [+proj] text"). Files
# each under its +project (or the top blob), dated by completion and tagged
# created:<date>. Processes oldest-first so headings get the earliest date and
# entries end up newest-first. Skips lines already in $JOURNAL_FILE.imported.
import_done() {
  local src="${1:-${DONE_FILE:-$HOME/done.txt}}"
  [[ -f "$src" ]] || { echo "journal: no done file at $src" >&2; exit 1; }
  local log="$JOURNAL_FILE.imported"; touch "$log"
  local count=0 line rest comp crea alias entry text w
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" == x\ * ]] || continue
    grep -qxF -- "$line" "$log" && continue
    rest="${line#x }"
    comp="${rest%% *}"; rest="${rest#* }"
    [[ "$comp" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || continue
    crea=""
    if [[ "${rest%% *}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then crea="${rest%% *}"; rest="${rest#* }"; fi
    alias=""; text=""; read -ra parts <<< "$rest"
    for w in "${parts[@]}"; do
      if [[ -z "$alias" && "$w" == +?* ]]; then alias="${w#+}"
      else text+="${text:+ }$w"; fi
    done
    entry="- $comp $text"; [[ -n "$crea" ]] && entry+=" created:$crea"
    insert_entry "$alias" "" "$entry" "$comp"
    printf '%s\n' "$line" >> "$log"
    count=$((count + 1))
  done < <(sort "$src")
  echo "journal: imported $count task(s) from $src"
}

# Parse "+alias" / "+alias=name" plus entry text from the args into the globals
# alias, name, words[]. The first "+..." token selects the project; the rest is
# text. Shared by the add and note verbs.
parse_target() {
  alias="" name="" words=()
  local w
  for w in "$@"; do
    if [[ -z "$alias" && "$w" == +?* ]]; then
      w="${w#+}"
      alias="${w%%=*}"
      [[ "$w" == *=* ]] && name="${w#*=}"
    else
      words+=("$w")
    fi
  done
  return 0   # last "&&" above may be false; don't let that fail under set -e
}

case "${1:-}" in
  -h|--help) usage 0 ;;
  add|a)     shift ;;
  note|n)
    shift; parse_target "$@"
    [[ ${#words[@]} -gt 0 ]] || usage      # a note needs body text
    insert_entry "$alias" "$name" "- ${words[*]}" "$today" 1
    exit 0 ;;
  edit|e)    exec "${EDITOR:-vi}" "$JOURNAL_FILE" ;;
  import)    shift; import_done "${1:-}"; exit 0 ;;
  ls|list)
    shift
    if   [[ $# -eq 0 ]];                then cat "$JOURNAL_FILE"
    elif [[ $# -eq 1 && "$1" == +?* ]]; then show_section "${1#+}"
    elif [[ $# -eq 1 && "$1" == @?* ]]; then show_grouped "$1"
    else                                     show_grouped "$*"
    fi | colorize
    exit 0 ;;
  *)         usage ;;
esac

# --- add ---
# First "+alias" or "+alias=name" arg selects the project; the rest is entry text.
parse_target "$@"

# A bare "+alias" with no entry text and no rename is not a valid add.
[[ -n "$alias" || ${#words[@]} -gt 0 ]] || usage

entry=""
[[ ${#words[@]} -gt 0 ]] && entry="- $today ${words[*]}"
insert_entry "$alias" "$name" "$entry" "$today"
