#!/usr/bin/env bash
#
# journal - a todo.txt-style journal grouped by project.
#
# Usage:
#   journal a[dd] some entry text              # add an unassigned entry (top)
#   journal a[dd] '+alias=Display Name' text   # create/name a project, add an entry
#   journal a[dd] +alias some entry text       # add an entry to a project
#   journal a[dd] '+alias=New Name'            # rename a project (no entry text)
#   journal ls                                 # show the whole journal
#   journal ls +alias                          # show one section
#   journal ls @context                        # entries with @context, grouped
#   journal ls TERM                            # entries containing TERM, grouped
#   journal import [done.txt]                  # import completed todo.txt tasks
#   journal e[dit]                             # open the journal in $EDITOR
#   journal -h                                 # this help
#
# ls and list are synonyms. Quote any token with spaces. File is $JOURNAL_FILE,
# or ~/journal.txt.
#
# import reads todo.txt "done.txt" lines ("x <done> [<created>] [+proj] text"),
# files each under its +project (or the top blob), dated by completion date and
# tagged "created:<date>". The source defaults to $DONE_FILE or ~/done.txt and is
# left untouched; imported lines are logged to $JOURNAL_FILE.imported so re-runs
# skip them.
#
# Config: an optional file (default ~/.journal.txt.cfg, or $JOURNAL_CONFIG) may
# set JOURNAL_FILE, DONE_FILE, or the C_* colors below. `ls` colorizes when
# stdout is a terminal; set JOURNAL_PLAIN=1 in the config to disable.

set -euo pipefail

CONFIG="${JOURNAL_CONFIG:-$HOME/.journal.txt.cfg}"
# shellcheck source=/dev/null
[[ -f "$CONFIG" ]] && . "$CONFIG"

JOURNAL_FILE="${JOURNAL_FILE:-$HOME/journal.txt}"
touch "$JOURNAL_FILE"
today="$(date +%F)"

# Color codes for `ls`, overridable from the config file. Applied to headings
# (whole line) and to date / +project / @context / key:value tokens in entries.
C_HEAD="${C_HEAD:-$'\033[1m'}"    # bold
C_DATE="${C_DATE:-$'\033[34m'}"   # blue
C_PROJ="${C_PROJ:-$'\033[32m'}"   # green
C_CTX="${C_CTX:-$'\033[33m'}"     # yellow
C_META="${C_META:-$'\033[2m'}"    # dim
C_RESET="${C_RESET:-$'\033[0m'}"

# Color on when writing to a terminal, unless JOURNAL_PLAIN is set.
if [[ -t 1 && -z "${JOURNAL_PLAIN:-}" ]]; then COLOR=1; else COLOR=0; fi

# is_heading(): line is "YYYY-MM-DD ... +alias ...". Prepended to each awk below.
IS_HEADING='
  function is_heading(  i) {
    if ($1 !~ /^[0-9]{4}-[0-9]{2}-[0-9]{2}$/) return 0
    for (i = 2; i <= NF; i++) if ($i ~ /^\+/) return 1
    return 0
  }'

# User text reaches awk via ENVIRON[...], not -v, to avoid backslash escaping.

usage() {
  local code="${1:-2}" fd=2
  [[ $code -eq 0 ]] && fd=1
  awk '/^#!/ { next } /^#/ { sub(/^#\ ?/, ""); print; next } { exit }' "$0" >&"$fd"
  exit "$code"
}

# Colorize `ls` output on stdin when $COLOR is 1; otherwise pass through. Headings
# are bold; within entries the leading date, +project, @context, and key:value
# metadata tokens are tinted. Colors come from the C_* vars (see config).
colorize() {
  if [[ "$COLOR" != 1 ]]; then cat; return; fi
  C_HEAD="$C_HEAD" C_DATE="$C_DATE" C_PROJ="$C_PROJ" C_CTX="$C_CTX" \
  C_META="$C_META" C_RESET="$C_RESET" awk "$IS_HEADING"'
    { hd=ENVIRON["C_HEAD"]; dt=ENVIRON["C_DATE"]; pj=ENVIRON["C_PROJ"]
      cx=ENVIRON["C_CTX"]; mt=ENVIRON["C_META"]; rs=ENVIRON["C_RESET"] }
    is_heading() { print hd $0 rs; next }
    {
      for (i = 1; i <= NF; i++) {
        c = ""
        if ($i ~ /^[0-9]{4}-[0-9]{2}-[0-9]{2}$/) c = dt
        else if ($i ~ /^\+./) c = pj
        else if ($i ~ /^@./) c = cx
        else if ($i ~ /^[^:[:space:]]+:[^:[:space:]]+$/) c = mt
        printf "%s%s%s%s", (i > 1 ? " " : ""), c, $i, (c != "" ? rs : "")
      }
      print ""
    }
  '
}

# Show entries matching a term, grouped under their project headings. A term
# starting with "@" matches a whole field (context); otherwise it's a literal
# substring of the line.
show_grouped() {
  term="$1" awk "$IS_HEADING"'
    function hit(  i) {
      if (ENVIRON["term"] ~ /^@/) {
        for (i = 1; i <= NF; i++) if ($i == ENVIRON["term"]) return 1
        return 0
      }
      return index($0, ENVIRON["term"]) > 0
    }
    is_heading() { head = $0; shown = 0; next }
    hit() {
      if (!shown) { if (group++) print ""; if (head != "") print head; shown = 1 }
      print
    }
  ' "$JOURNAL_FILE"
}

# Show a whole project section by alias.
show_section() {
  alias="$1" awk "$IS_HEADING"'
    is_heading() {
      show = 0
      for (i = 2; i <= NF; i++) if ($i == "+" ENVIRON["alias"]) show = 1
    }
    show
  ' "$JOURNAL_FILE"
}

# Insert an entry, keeping each section newest-first by date. Args:
#   $1 alias  ""=top blob, else project (created if new)
#   $2 name   rename the project heading if non-empty
#   $3 entry  the "- DATE text" line ("" to only create/rename a section)
#   $4 edate  the entry's date, used both to place it and to date a new heading
# A live add passes today's date so it lands on top, as before; import passes a
# past completion date so it slots in chronologically.
insert_entry() {
  local tmp; tmp="$(mktemp "$JOURNAL_FILE.XXXXXX")"
  alias="$1" name="$2" entry="$3" edate="$4" awk "$IS_HEADING"'
    function bdate(s,  a) {
      if (s ~ /^- [0-9]{4}-[0-9]{2}-[0-9]{2}/) { split(s, a, " "); return a[2] }
      return ""
    }
    function matches(  i) { for (i = 2; i <= NF; i++) if ($i == "+" alias) return 1; return 0 }
    { L[NR] = $0 }
    END {
      alias = ENVIRON["alias"]; name = ENVIRON["name"]
      entry = ENVIRON["entry"]; edate = ENVIRON["edate"]; n = NR

      if (n == 0) {                                   # empty file
        if (alias != "") print edate " " (name != "" ? name : alias) " +" alias
        if (entry != "") print entry
        exit
      }

      fh = hstart = 0                                 # first heading, target heading
      for (i = 1; i <= n; i++) {
        $0 = L[i]
        if (is_heading()) { if (!fh) fh = i; if (alias != "" && !hstart && matches()) hstart = i }
      }

      if (alias == "") {                              # top blob
        blobend = fh ? fh - 1 : n
        ins = 0
        for (i = 1; i <= blobend; i++) { d = bdate(L[i]); if (d != "" && d <= edate) { ins = i; break } }
        if (!ins) ins = blobend + 1
      } else if (!hstart) {                           # new section at end
        for (i = 1; i <= n; i++) print L[i]
        if (L[n] !~ /^[[:space:]]*$/) print ""
        print edate " " (name != "" ? name : alias) " +" alias
        if (entry != "") print entry
        exit
      } else {                                        # existing section
        if (name != "") { $0 = L[hstart]; L[hstart] = $1 " " name " +" alias }
        secend = n
        for (i = hstart + 1; i <= n; i++) { $0 = L[i]; if (is_heading()) { secend = i - 1; break } }
        ins = 0
        for (i = hstart + 1; i <= secend; i++) { d = bdate(L[i]); if (d != "" && d <= edate) { ins = i; break } }
        if (!ins) { last = hstart; for (i = hstart + 1; i <= secend; i++) if (L[i] !~ /^[[:space:]]*$/) last = i; ins = last + 1 }
      }

      $0 = L[ins]; blob_before_head = (alias == "" && ins <= n && is_heading())
      for (i = 1; i <= n; i++) {
        if (i == ins && entry != "") { print entry; if (blob_before_head) print "" }
        print L[i]
      }
      if (ins == n + 1 && entry != "") print entry
    }
  ' "$JOURNAL_FILE" > "$tmp"
  mv "$tmp" "$JOURNAL_FILE"
}

# Import completed todo.txt tasks ("x <done> [<created>] [+proj] text"). Files
# each under its +project (or the top blob), dated by completion and tagged
# created:<date>. Processes oldest-first so headings get the earliest date and
# entries end up newest-first. Skips lines already in $JOURNAL_FILE.imported.
import_done() {
  local src="${1:-${DONE_FILE:-$HOME/done.txt}}"
  [[ -f "$src" ]] || { echo "journal: no done file at $src" >&2; exit 1; }
  local log="$JOURNAL_FILE.imported"; touch "$log"
  local count=0 line rest comp crea alias entry text w
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" == x\ * ]] || continue
    grep -qxF -- "$line" "$log" && continue
    rest="${line#x }"
    comp="${rest%% *}"; rest="${rest#* }"
    [[ "$comp" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || continue
    crea=""
    if [[ "${rest%% *}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then crea="${rest%% *}"; rest="${rest#* }"; fi
    alias=""; text=""; read -ra parts <<< "$rest"
    for w in "${parts[@]}"; do
      if [[ -z "$alias" && "$w" == +?* ]]; then alias="${w#+}"
      else text+="${text:+ }$w"; fi
    done
    entry="- $comp $text"; [[ -n "$crea" ]] && entry+=" created:$crea"
    insert_entry "$alias" "" "$entry" "$comp"
    printf '%s\n' "$line" >> "$log"
    count=$((count + 1))
  done < <(sort "$src")
  echo "journal: imported $count task(s) from $src"
}

case "${1:-}" in
  -h|--help) usage 0 ;;
  add|a)     shift ;;
  edit|e)    exec "${EDITOR:-vi}" "$JOURNAL_FILE" ;;
  import)    shift; import_done "${1:-}"; exit 0 ;;
  ls|list)
    shift
    if   [[ $# -eq 0 ]];                then cat "$JOURNAL_FILE"
    elif [[ $# -eq 1 && "$1" == +?* ]]; then show_section "${1#+}"
    elif [[ $# -eq 1 && "$1" == @?* ]]; then show_grouped "$1"
    else                                     show_grouped "$*"
    fi | colorize
    exit 0 ;;
  *)         usage ;;
esac

# --- add ---
# First "+alias" or "+alias=name" arg selects the project; the rest is entry text.
alias="" name="" words=()
for w in "$@"; do
  if [[ -z "$alias" && "$w" == +?* ]]; then
    w="${w#+}"
    alias="${w%%=*}"
    [[ "$w" == *=* ]] && name="${w#*=}"
  else
    words+=("$w")
  fi
done

# A bare "+alias" with no entry text and no rename is not a valid add.
[[ -n "$alias" || ${#words[@]} -gt 0 ]] || usage

entry=""
[[ ${#words[@]} -gt 0 ]] && entry="- $today ${words[*]}"
insert_entry "$alias" "$name" "$entry" "$today"
