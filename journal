#!/usr/bin/env bash
#
# journal - a todo.txt-style journal grouped by project.
#
# Usage:
#   journal                                        # show the whole journal
#   journal some entry text                        # add an unassigned entry (top)
#   journal '+alias=Display Name' some entry text  # create/name, add an entry
#   journal +alias some entry text                 # add an entry
#   journal '+alias=New Name'                      # rename (no entry added)
#   journal +alias                                 # show one section
#   journal @context                               # show entries with @context
#   journal -h                                     # this help
#
# Quote any token with spaces. File is $JOURNAL_FILE, or ~/journal.txt.

set -euo pipefail

JOURNAL_FILE="${JOURNAL_FILE:-$HOME/journal.txt}"
touch "$JOURNAL_FILE"
today="$(date +%F)"

# is_heading(): line is "YYYY-MM-DD ... +alias ...". Prepended to each awk below.
IS_HEADING='
  function is_heading(  i) {
    if ($1 !~ /^[0-9]{4}-[0-9]{2}-[0-9]{2}$/) return 0
    for (i = 2; i <= NF; i++) if ($i ~ /^\+/) return 1
    return 0
  }'

# User text reaches awk via ENVIRON[...], not -v, to avoid backslash escaping.

usage() {
  local code="${1:-2}" fd=2
  [[ $code -eq 0 ]] && fd=1
  awk '/^#!/ { next } /^#/ { sub(/^#\ ?/, ""); print; next } { exit }' "$0" >&"$fd"
  exit "$code"
}

case "${1:-}" in
  -h|--help) usage 0 ;;
  "")        cat "$JOURNAL_FILE"; exit 0 ;;
esac

if [[ $# -eq 1 && "$1" == @?* ]]; then
  ctx="$1" awk "$IS_HEADING"'
    function has_ctx(  i) { for (i = 1; i <= NF; i++) if ($i == ENVIRON["ctx"]) return 1; return 0 }
    is_heading() { head = $0; shown = 0; next }
    has_ctx() {
      if (!shown) { if (group++) print ""; if (head != "") print head; shown = 1 }
      print
    }
  ' "$JOURNAL_FILE"
  exit 0
fi

# First "+alias" or "+alias=name" arg selects the project; the rest is entry text.
alias="" name="" words=()
for w in "$@"; do
  if [[ -z "$alias" && "$w" == +?* ]]; then
    w="${w#+}"
    alias="${w%%=*}"
    [[ "$w" == *=* ]] && name="${w#*=}"
  else
    words+=("$w")
  fi
done

# No +alias: add an unassigned entry to the top blob.
if [[ -z "$alias" ]]; then
  [[ ${#words[@]} -gt 0 ]] || usage
  tmp="$(mktemp "$JOURNAL_FILE.XXXXXX")"
  entry="- $today ${words[*]}" awk "$IS_HEADING"'
    NR == 1 { print ENVIRON["entry"]; if (is_heading()) print "" }
    { print }
    END { if (NR == 0) print ENVIRON["entry"] }
  ' "$JOURNAL_FILE" > "$tmp"
  mv "$tmp" "$JOURNAL_FILE"
  exit 0
fi

# Neither entry text nor a name: show the section.
if [[ ${#words[@]} -eq 0 && -z "$name" ]]; then
  alias="$alias" awk "$IS_HEADING"'
    is_heading() {
      show = 0
      for (i = 2; i <= NF; i++) if ($i == "+" ENVIRON["alias"]) show = 1
    }
    show
  ' "$JOURNAL_FILE"
  exit 0
fi

entry=""
[[ ${#words[@]} -gt 0 ]] && entry="- $today ${words[*]}"

# Add under the section (newest first), creating it if the alias is new.
tmp="$(mktemp "$JOURNAL_FILE.XXXXXX")"
alias="$alias" name="$name" today="$today" entry="$entry" \
awk "$IS_HEADING"'
  function matches(  i) {
    for (i = 2; i <= NF; i++) if ($i == "+" ENVIRON["alias"]) return 1
    return 0
  }
  BEGIN { alias = ENVIRON["alias"]; name = ENVIRON["name"]
          today = ENVIRON["today"]; entry = ENVIRON["entry"] }
  is_heading() && matches() {
    if (name != "") $0 = $1 " " name " +" alias
    print
    if (entry != "") print entry
    added = 1
    blank = 0
    next
  }
  { print; blank = ($0 ~ /^[[:space:]]*$/) }
  END {
    if (!added) {
      if (NR > 0 && !blank) print ""
      print today " " (name != "" ? name : alias) " +" alias
      if (entry != "") print entry
    }
  }
' "$JOURNAL_FILE" > "$tmp"
mv "$tmp" "$JOURNAL_FILE"
